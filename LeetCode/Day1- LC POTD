//1855. Maximum Distance Between a Pair of Values
//we need to calculate the maximum distance betweent given two arrary(decreasing order)

int maxDistance(vector<int>& nums1, vector<int>& nums2) {
        int i = 0, j = 0;
        int maxi = 0;
        while(i < nums1.size() && j < nums2.size()){
            if(nums1[i] <= nums2[j]){
                maxi = max(maxi, j - i);
                j++;
            }else{
                i++;
            }
        }
        return maxi;
    }
