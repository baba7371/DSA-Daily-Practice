POTD: Min Swaps to Group 1s
Approach:
Count total number of 1s → k
Ab window size = k
Har window me count karo kitne 1s hai
Maximum 1s wali window find karo
Swaps = k - maxOnes

int minSwaps(vector<int>& arr) {
        // code here
        int totalOnes = 0;
        
        for(int x: arr){
            if(x == 1) totalOnes++;
        }
        
        if(totalOnes == 0) return -1;
        
        int currOnes = 0;
        
        for(int i = 0; i < totalOnes; i++){
            if(arr[i] == 1)currOnes++;
        }
        
        int maxOnes = currOnes;
        
        for(int i = totalOnes; i < arr.size(); i++){
            if(arr[i] == 1)currOnes++;
            if(arr[i - totalOnes] == 1)currOnes--; 
            
            maxOnes = max(maxOnes, currOnes);
        }
        return totalOnes - maxOnes;
    }
